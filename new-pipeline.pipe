{
  "components": [
    {
      "id": "webhook_model_input",
      "provider": "webhook",
      "name": "Model Folder Analysis Webhook",
      "config": {
        "hideForm": true,
        "mode": "Source",
        "parameters": {
          "model_input_folder": "model_input/Transfer-Model_original",
          "target": "amd-vitis-ai",
          "framework_hint": "pytorch"
        },
        "type": "webhook",
        "name": "Model Folder Analysis Webhook"
      },
      "ui": {
        "position": {
          "x": 100,
          "y": 360
        },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "agent_model_extractor",
      "provider": "agent_deepagent",
      "name": "Model Extraction Agent",
      "config": {
        "default": {
          "advanced_mode": false,
          "instructions": [
            "Read the incoming webhook payload. It should include model_input_folder, target, and framework_hint. Default to model_input_folder=model_input/Transfer-Model_original, target=amd-vitis-ai, and framework_hint=pytorch if fields are missing.",
            "Use the filesystem tool to inspect the local model_input_folder path.",
            "List Python files and prioritize files containing nn.Module classes, forward methods, layer definitions, tensor operations, dataloaders, and training or evaluation entry points.",
            "Extract model classes, __init__ layer definitions, forward() logic, helper functions, and explicit tensor operations.",
            "Return structured JSON with model_input_folder, framework, candidate files, discovered classes/functions, and an operator inventory with file path and usage context."
          ]
        },
        "name": "Model Extractor"
      },
      "ui": {
        "position": {
          "x": 320,
          "y": 360
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "questions",
          "from": "webhook_model_input"
        }
      ]
    },
    {
      "id": "agent_rag_vitis_docs",
      "provider": "agent_deepagent",
      "name": "Vitis AI Compatibility Agent",
      "config": {
        "default": {
          "advanced_mode": false,
          "instructions": [
            "Receive the operator inventory from the Model Extraction Agent.",
            "Fetch and use the AMD Vitis AI supported operators and DPU limitations documentation: https://docs.amd.com/r/3.0-English/ug1414-vitis-ai/Supported-Operators-and-DPU-Limitations.",
            "Classify each extracted operator as supported on DPU, conditionally supported, CPU fallback likely, or unsupported/rewrite required.",
            "Call out quantization, static shape, custom op, grouped convolution, dilation, transpose convolution, elementwise, reduction, slicing, and activation risks.",
            "Return JSON with supported_ops count, unsupported_ops list, constraints_per_op, dpu_risks, and evidence for each classification."
          ]
        },
        "name": "Vitis Compatibility"
      },
      "ui": {
        "position": {
          "x": 560,
          "y": 360
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "questions",
          "from": "agent_model_extractor"
        }
      ]
    },
    {
      "id": "agent_proposal_conservative",
      "provider": "agent_deepagent",
      "name": "Conservative Proposal Agent",
      "config": {
        "default": {
          "advanced_mode": false,
          "instructions": [
            "Receive the compatibility report and unsupported operations list.",
            "Generate a conservative refactoring strategy that minimizes code changes and prioritizes low-risk replacements.",
            "For each unsupported or risky operator, suggest one replacement operator or code change with reasoning.",
            "Estimate final Vitis AI compatibility percentage, likely accuracy impact, and development effort.",
            "Return JSON with strategy, changes array, metrics, implementation notes, and any accepted residual risks."
          ]
        },
        "name": "Conservative Proposal"
      },
      "ui": {
        "position": {
          "x": 820,
          "y": 250
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "questions",
          "from": "agent_rag_vitis_docs"
        }
      ]
    },
    {
      "id": "agent_proposal_aggressive",
      "provider": "agent_deepagent",
      "name": "Aggressive Proposal Agent",
      "config": {
        "default": {
          "advanced_mode": false,
          "instructions": [
            "Receive the compatibility report and unsupported operations list.",
            "Generate an aggressive refactoring strategy that targets full Vitis AI DPU compatibility where practical.",
            "Replace unsupported or risky operations with static-shape, quantization-friendly, DPU-supported blocks.",
            "Include INT8 quantization guidance, calibration dataset requirements, and deployment-oriented code structure.",
            "Return JSON with strategy, changes array, quantization_plan, metrics, code_structure, and migration checklist."
          ]
        },
        "name": "Aggressive Proposal"
      },
      "ui": {
        "position": {
          "x": 820,
          "y": 470
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "questions",
          "from": "agent_rag_vitis_docs"
        }
      ]
    },
    {
      "id": "agent_report_writer",
      "provider": "agent_deepagent",
      "name": "Report Writer Agent",
      "config": {
        "default": {
          "advanced_mode": false,
          "instructions": [
            "Combine the model extraction, Vitis compatibility audit, conservative proposal, and aggressive proposal into one Markdown report.",
            "The report must include: model input folder scanned, model files discovered, classes/functions extracted, operator inventory, compatibility table, DPU risks, conservative plan, aggressive plan, and migration checklist.",
            "Use the filesystem tool to write the report to reports/model_input_vitis_ai_compatibility.md.",
            "Return a concise final answer that includes the report path."
          ]
        },
        "name": "Report Writer"
      },
      "ui": {
        "position": {
          "x": 1060,
          "y": 360
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "questions",
          "from": "agent_proposal_conservative"
        },
        {
          "lane": "questions",
          "from": "agent_proposal_aggressive"
        }
      ]
    },
    {
      "id": "llm_openai_1",
      "provider": "llm_openai",
      "name": "OpenAI Reasoning Model",
      "config": {
        "profile": "openai-5",
        "openai-5": {
          "apikey": "${OPENAI_API_KEY}"
        },
        "name": "OpenAI Reasoning Model"
      },
      "ui": {
        "position": {
          "x": 320,
          "y": 660
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "control": [
        {
          "classType": "llm",
          "from": "agent_model_extractor"
        },
        {
          "classType": "llm",
          "from": "agent_rag_vitis_docs"
        },
        {
          "classType": "llm",
          "from": "agent_proposal_conservative"
        },
        {
          "classType": "llm",
          "from": "agent_proposal_aggressive"
        },
        {
          "classType": "llm",
          "from": "agent_report_writer"
        }
      ]
    },
    {
      "id": "tool_http_request_1",
      "provider": "tool_http_request",
      "name": "AMD Documentation Fetcher",
      "config": {
        "type": "tool_http_request",
        "allowGET": true,
        "allowPOST": false,
        "allowPUT": false,
        "allowPATCH": false,
        "allowDELETE": false,
        "allowHEAD": true,
        "allowOPTIONS": false,
        "urlWhitelist": [
          {
            "whitelistPattern": "^https://docs\\.amd\\.com/.*"
          }
        ],
        "rateLimitPerSecond": 5,
        "rateLimitPerMinute": 60,
        "maxConcurrentRequests": 4,
        "name": "AMD Documentation Fetcher"
      },
      "ui": {
        "position": {
          "x": 560,
          "y": 660
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "control": [
        {
          "classType": "tool",
          "from": "agent_rag_vitis_docs"
        }
      ]
    },
    {
      "id": "tool_filesystem_1",
      "provider": "tool_filesystem",
      "name": "Model Input and Report Filesystem Tool",
      "config": {
        "type": "tool_filesystem",
        "allowRead": true,
        "allowWrite": true,
        "allowList": true,
        "allowMkdir": true,
        "allowStat": true,
        "allowDelete": false,
        "pathWhitelist": [
          {
            "whitelistPattern": "^model_input/.*"
          },
          {
            "whitelistPattern": "^reports/.*"
          },
          {
            "whitelistPattern": "^analysis/.*"
          }
        ],
        "name": "Model Input and Report Filesystem Tool"
      },
      "ui": {
        "position": {
          "x": 820,
          "y": 660
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "control": [
        {
          "classType": "tool",
          "from": "agent_model_extractor"
        },
        {
          "classType": "tool",
          "from": "agent_report_writer"
        }
      ]
    },
    {
      "id": "response_final_answers",
      "provider": "response_answers",
      "name": "Return Answers",
      "config": {
        "laneName": "answers",
        "name": "Return Analysis Results"
      },
      "ui": {
        "position": {
          "x": 1260,
          "y": 360
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "answers",
          "from": "agent_report_writer"
        }
      ]
    }
  ],
  "project_id": "vitis-ai-analyzer-2024",
  "isLocked": false,
  "snapToGrid": true,
  "snapGridSize": [
    10,
    10
  ],
  "version": 1,
  "docRevision": 42,
  "metadata": {
    "name": "Vitis AI Model Compatibility Analyzer",
    "description": "Analyze a local deep learning model folder for Vitis AI hardware compatibility and propose refactoring strategies",
    "author": "Hackathon Team",
    "created_date": "2026-06-05",
    "tags": [
      "vitis-ai",
      "model-analysis",
      "hardware-optimization",
      "porting"
    ],
    "flow_description": "Webhook -> Extract local model folder -> Check Vitis docs -> Parallel proposals -> Write report -> Return results"
  }
}